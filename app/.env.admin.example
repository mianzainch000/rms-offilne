# ============================================================
# OWNER-ONLY ADMIN CONFIG — never bundle this, never send to customers
# ============================================================
# Yeh file sirf aapki apni dev machine par hoti hai. Isay `npm run
# license-admin` aur owner-tools-KEEP-PRIVATE/manage-license.js dono use
# karte hain — customer ki app iska naam tak nahi janti.
#
# Yeh aapki APNI (owner ki) central Atlas cluster hai jahan sab customers
# ke "licenses" collection ke records rehte hain (activate/deactivate
# status). license-api/server.js bhi isi value ko apne hosting (Render/
# Vercel) ke environment variables mein separately set karta hai.
LICENSE_DB_URI=mongodb+srv://YOUR_OWNER_ATLAS_CONNECTION_STRING
